<UserControl x:Class="Movie_Hub.Views.FavouritesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1080">

    <UserControl.Resources>
        <!-- Empty-state panel: visible only when HasFavourites is False -->
        <Style x:Key="EmptyPanelStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasFavourites}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- List panel: visible only when HasFavourites is True -->
        <Style x:Key="ListPanelStyle" TargetType="ScrollViewer">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasFavourites}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BgDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ROW 0 — Header -->
        <Border Grid.Row="0" Background="{StaticResource BgSidebar}" Padding="28,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource TextPrimary}"
                               FontSize="22" FontWeight="Bold" FontFamily="Segoe UI">
                        <Run Text="❤️  "/><Run Text="My Favourites"/>
                    </TextBlock>
                    <TextBlock Text="Movies you've saved this session"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="13" FontFamily="Segoe UI" Margin="0,3,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource GhostBtn}"
                        Content="✕  Clear All"
                        Command="{Binding ClearAllCommand}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ROW 1 — Content -->
        <Grid Grid.Row="1">

            <!-- EMPTY STATE -->
            <StackPanel Style="{StaticResource EmptyPanelStyle}"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🎬" FontSize="56" HorizontalAlignment="Center" Opacity="0.25"/>
                <TextBlock Text="Nothing saved yet"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="18" FontWeight="SemiBold" FontFamily="Segoe UI"
                           HorizontalAlignment="Center" Margin="0,16,0,0"/>
                <TextBlock Text="Browse movies and click ★ to save them here."
                           Foreground="{StaticResource TextMuted}"
                           FontSize="13" FontFamily="Segoe UI"
                           HorizontalAlignment="Center" Margin="0,6,0,0" Opacity="0.7"/>
            </StackPanel>

            <!-- FAVOURITES GRID -->
            <ScrollViewer Style="{StaticResource ListPanelStyle}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="22,18">
                <ItemsControl ItemsSource="{Binding Favourites}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="190" Margin="6"
                                    Background="{StaticResource BgCard}"
                                    CornerRadius="8"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="1"
                                    Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentGold}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <StackPanel>
                                    <!-- Poster placeholder -->
                                    <Border Background="#0E0E28" Height="260" CornerRadius="8,8,0,0">
                                        <TextBlock Text="★" FontSize="44"
                                                   Foreground="{StaticResource AccentGold}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Opacity="0.6"/>
                                    </Border>

                                    <StackPanel Margin="10,8,10,10">
                                        <TextBlock Text="{Binding PrimaryTitle}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI"
                                                   MaxHeight="36" TextTrimming="CharacterEllipsis"
                                                   TextWrapping="Wrap" ToolTip="{Binding PrimaryTitle}"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding StartYear}"
                                                       Foreground="{StaticResource TextMuted}"
                                                       FontSize="11" FontFamily="Segoe UI"/>
                                            <TextBlock Text=" · " Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                            <TextBlock Foreground="{StaticResource TextMuted}"
                                                       FontSize="11" FontFamily="Segoe UI">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} min">
                                                        <Binding Path="RuntimeMinutes" TargetNullValue="N/A"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Genre + Rating row -->
                                        <Grid Margin="0,5,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Background="#0E0E28"
                                                    CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                                <TextBlock Foreground="{StaticResource AccentGold}"
                                                           FontSize="10" FontFamily="Segoe UI"
                                                           Text="{Binding Genres[0].Name, FallbackValue='–'}"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="★" Foreground="#FFD700" FontSize="12"/>
                                                <TextBlock Foreground="{StaticResource TextPrimary}"
                                                           FontSize="12" FontFamily="Segoe UI" Margin="2,0,0,0">
                                                    <Binding Path="Rating.AverageRating"
                                                             StringFormat="{}{0:F1}"
                                                             FallbackValue="N/A"
                                                             TargetNullValue="N/A"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Remove button -->
                                        <Button Style="{StaticResource DangerBtn}"
                                                Content="✕  Remove"
                                                HorizontalAlignment="Stretch"
                                                Command="{Binding DataContext.RemoveCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ROW 2 — Status bar -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSidebar}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="28,10">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextMuted}"
                       FontSize="12" FontFamily="Segoe UI"/>
        </Border>
    </Grid>
</UserControl>