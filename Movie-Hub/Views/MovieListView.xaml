<UserControl x:Class="Movie_Hub.Views.MovieListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720" d:DesignWidth="1080">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgDark"       Color="#0F0F0F"/>
        <SolidColorBrush x:Key="BgCard"       Color="#1A1A2E"/>
        <SolidColorBrush x:Key="BgFilter"     Color="#16213E"/>
        <SolidColorBrush x:Key="AccentGold"   Color="#E2B96F"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#F5F5F5"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#9E9E9E"/>
        <SolidColorBrush x:Key="BorderSubtle" Color="#2A2A4A"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background"    Value="#1E1E3A"/>
            <Setter Property="Foreground"    Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush"    Value="{StaticResource AccentGold}"/>
            <Setter Property="BorderBrush"   Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="10,8"/>
            <Setter Property="FontSize"      Value="13"/>
            <Setter Property="FontFamily"    Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background"    Value="#1E1E3A"/>
            <Setter Property="Foreground"    Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"   Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="8,6"/>
            <Setter Property="FontSize"      Value="13"/>
            <Setter Property="FontFamily"    Value="Segoe UI"/>
        </Style>

        <Style x:Key="GoldBtn" TargetType="Button">
            <Setter Property="Background"    Value="{StaticResource AccentGold}"/>
            <Setter Property="Foreground"    Value="#0F0F0F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"      Value="13"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="FontFamily"    Value="Segoe UI"/>
            <Setter Property="Padding"       Value="16,8"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F0C97E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#444"/>
                                <Setter Property="Foreground" Value="#777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E1E3A"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"          Value="6"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BgDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ROW 0 — Header & Search -->
        <Border Grid.Row="0" Background="#16213E" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="MovieHub"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="24" FontWeight="Bold" FontFamily="Segoe UI"/>
                    <TextBlock Text="Discover your favourite movies both old and new"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="13" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox Width="280"
                             Text="{Binding SearchText, Mode=TwoWay,
                                            UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource InputStyle}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="🔍  Search by title…"
                                                                   Foreground="#555"
                                                                   FontSize="13" FontFamily="Segoe UI"
                                                                   Margin="10,0,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Button Style="{StaticResource GoldBtn}"
                            Content="Search"
                            Command="{Binding SearchCommand}"
                            Margin="8,0,0,0" Width="80"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 1 — Filter Panel -->
        <Border Grid.Row="1"
                Background="{StaticResource BgFilter}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,12">
            <WrapPanel Orientation="Horizontal">

                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="GENRE"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                               Margin="0,0,0,4"/>
                    <ComboBox Style="{StaticResource ComboStyle}"
                              Width="160"
                              ItemsSource="{Binding Genres}"
                              SelectedItem="{Binding SelectedGenre, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="FROM YEAR"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                               Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource InputStyle}"
                             Width="80"
                             Text="{Binding YearFrom, Mode=TwoWay,
                                            UpdateSourceTrigger=PropertyChanged,
                                            TargetNullValue=''}"/>
                </StackPanel>

                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="TO YEAR"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                               Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource InputStyle}"
                             Width="80"
                             Text="{Binding YearTo, Mode=TwoWay,
                                            UpdateSourceTrigger=PropertyChanged,
                                            TargetNullValue=''}"/>
                </StackPanel>

                <StackPanel Margin="0,0,20,0">
                    <TextBlock Foreground="{StaticResource TextMuted}"
                               FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                               Margin="0,0,0,4">
                        <Run Text="MIN RATING  ★ "/>
                        <Run Text="{Binding MinRating, StringFormat='{}{0:F1}', TargetNullValue='Any'}"/>
                    </TextBlock>
                    <Slider Minimum="0" Maximum="10"
                            TickFrequency="0.5"
                            IsSnapToTickEnabled="True"
                            Width="150"
                            Value="{Binding MinRating, Mode=TwoWay, TargetNullValue=0}"
                            Foreground="{StaticResource AccentGold}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="4,0,0,0">
                    <Button Style="{StaticResource GoldBtn}"
                            Content="Apply Filters"
                            Command="{Binding FilterCommand}"
                            Width="110"/>
                    <Button Style="{StaticResource GhostBtn}"
                            Content="Clear All"
                            Command="{Binding ClearCommand}"
                            Margin="8,0,0,0" Width="80"/>
                </StackPanel>

            </WrapPanel>
        </Border>

        <!-- ROW 2 — Movie Grid -->
        <Grid Grid.Row="2">

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             Foreground="{StaticResource AccentGold}" Background="#2A2A4A"/>
                <TextBlock Text="Loading movies…"
                           Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="18,16">
                <ItemsControl ItemsSource="{Binding Movies}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="190" Margin="6">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush"
                                                        Value="{StaticResource AccentGold}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.ViewDetailsCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>

                                <StackPanel>
                                    <Border Background="#0E0E28" Height="260" CornerRadius="8,8,0,0">
                                        <TextBlock Text="🎬" FontSize="40"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#333"/>
                                    </Border>

                                    <StackPanel Margin="10,8,10,10">
                                        <TextBlock Text="{Binding PrimaryTitle}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   FontFamily="Segoe UI"
                                                   MaxHeight="36"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="Wrap"
                                                   ToolTip="{Binding PrimaryTitle}"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding StartYear}"
                                                       Foreground="{StaticResource TextMuted}"
                                                       FontSize="11" FontFamily="Segoe UI"/>
                                            <TextBlock Text=" · "
                                                       Foreground="{StaticResource TextMuted}"
                                                       FontSize="11"/>
                                            <TextBlock Foreground="{StaticResource TextMuted}"
                                                       FontSize="11" FontFamily="Segoe UI">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} min">
                                                        <Binding Path="RuntimeMinutes" TargetNullValue="N/A"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>

                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Background="#0E0E28"
                                                    CornerRadius="4" Padding="6,2"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Foreground="{StaticResource AccentGold}"
                                                           FontSize="10" FontFamily="Segoe UI"
                                                           Text="{Binding Genres[0].Name, FallbackValue='–'}"/>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="★" Foreground="#FFD700" FontSize="12"/>
                                                <TextBlock Foreground="{StaticResource TextPrimary}"
                                                           FontSize="12" FontFamily="Segoe UI"
                                                           Margin="2,0,0,0">
                                                    <TextBlock.Text>
                                                        <Binding Path="Rating.AverageRating"
                                                                 StringFormat="{}{0:F1}"
                                                                 FallbackValue="N/A"
                                                                 TargetNullValue="N/A"/>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>

                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ROW 3 — Status bar -->
        <Border Grid.Row="3"
                Background="#16213E"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="24,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextMuted}"
                       FontSize="12" FontFamily="Segoe UI"/>
        </Border>

    </Grid>
</UserControl>