<Page x:Class="Movie_Hub.Views.MovieDetailsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720" d:DesignWidth="1080"
      
      Title="MovieDetailsView" Width="810" Height="518">

    <Grid Background="#0F0F0F">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with Back Button -->
        <Border Grid.Row="0" Background="#16213E" Padding="20">
            <Button Content="← Back to Movies"
                    Command="{Binding NavigateBackCommand}"
                    Background="Transparent"
                    Foreground="#E2B96F"
                    BorderThickness="0"
                    Cursor="Hand"
                    HorizontalAlignment="Left"
                    FontSize="14"/>
        </Border>

        <!-- Content Area -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>

                <!-- Loading State -->
                <StackPanel Visibility="{Binding IsLoading}">
                    <TextBlock Text="Movie details" 
                               Foreground="White"
                               HorizontalAlignment="Center"
                               FontSize="16"/>
                </StackPanel>

                <!-- Error State -->
                <StackPanel Visibility="{Binding HasError}">
                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="Red"
                               FontSize="14"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Movie Details -->
                <StackPanel>

                    <!-- Title -->
                    <TextBlock Text="{Binding Movie.PrimaryTitle}" 
                               Foreground="White"
                               FontSize="28" 
                               FontWeight="Bold"/>

                    <!-- Year -->
                    <TextBlock Text="{Binding Movie.StartYear}" 
                               Foreground="#888"
                               FontSize="14"
                               Margin="0,10,0,0"/>

                    <!-- Rating -->
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="★ " Foreground="#E2B96F" FontSize="14"/>
                        <TextBlock Text="{Binding Movie.Rating.AverageRating}" Foreground="#E2B96F" FontSize="14"/>
                    </StackPanel>

                    <!-- Genres -->
                    <TextBlock Text="Genres" Foreground="#E2B96F" FontSize="16" FontWeight="SemiBold" Margin="0,20,0,10"/>
                    <ItemsControl ItemsSource="{Binding Genres}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A2E" CornerRadius="4" Padding="8,4" Margin="0,0,0,5">
                                    <TextBlock Text="{Binding Name}" Foreground="#E2B96F"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Cast -->
                    <TextBlock Text="Cast" Foreground="#E2B96F" FontSize="16" FontWeight="SemiBold" Margin="0,20,0,10"/>

                    <!-- Show count of cast members -->
                    <TextBlock Text="{Binding Cast.Count, StringFormat='Cast count: {0}'}"
                                Foreground="Yellow" 
                                FontSize="12" 
                                Margin="0,0,0,10"/>
                    
                    <ItemsControl ItemsSource="{Binding Cast}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A2E" CornerRadius="6" Padding="10,8" Margin="0,0,0,5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CharacterName}" Foreground="#888" FontSize="12" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>