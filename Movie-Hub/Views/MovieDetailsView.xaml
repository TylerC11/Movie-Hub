<UserControl x:Class="Movie_Hub.Views.MovieDetailsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720" d:DesignWidth="1080">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgDark"      Color="#0F0F0F"/>
        <SolidColorBrush x:Key="BgCard"      Color="#1A1A2E"/>
        <SolidColorBrush x:Key="AccentGold"  Color="#E2B96F"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#9E9E9E"/>
        <SolidColorBrush x:Key="BorderSubtle" Color="#2A2A4A"/>

        <Style x:Key="GoldBtn" TargetType="Button">
            <Setter Property="Background"    Value="{StaticResource AccentGold}"/>
            <Setter Property="Foreground"    Value="#0F0F0F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"      Value="13"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="FontFamily"    Value="Segoe UI"/>
            <Setter Property="Padding"       Value="16,8"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F0C97E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#444"/>
                                <Setter Property="Foreground" Value="#777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource AccentGold}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="tb"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontFamily="{TemplateBinding FontFamily}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tb" Property="TextDecorations" Value="Underline"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BgDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with Back Button -->
        <Border Grid.Row="0" Background="#16213E" Padding="24,16">
            <Button Style="{StaticResource GhostBtn}"
                    Content="← Back to Movies"
                    Command="{Binding NavigateBackCommand}"
                    HorizontalAlignment="Left"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="32,24">
            <StackPanel MaxWidth="800" HorizontalAlignment="Left">

                <!-- Loading indicator -->
                <TextBlock Text="Loading…"
                    Foreground="{StaticResource TextMuted}"
                    FontSize="14" FontFamily="Segoe UI">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#E05252"
                           FontSize="13" FontFamily="Segoe UI"/>

                <!-- Title -->
                <TextBlock Text="{Binding Movie.PrimaryTitle}"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="30" FontWeight="Bold" FontFamily="Segoe UI"
                           TextWrapping="Wrap"/>

                <!-- Year · Runtime -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="{Binding Movie.StartYear}"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="14" FontFamily="Segoe UI"/>
                    <TextBlock Text=" · "
                               Foreground="{StaticResource TextMuted}"
                               FontSize="14"/>
                    <TextBlock Foreground="{StaticResource TextMuted}"
                               FontSize="14" FontFamily="Segoe UI">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} min">
                                <Binding Path="Movie.RuntimeMinutes" TargetNullValue="N/A"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <!-- Rating -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="★ "
                               Foreground="{StaticResource AccentGold}"
                               FontSize="16"/>
                    <TextBlock Foreground="{StaticResource AccentGold}"
                               FontSize="16" FontFamily="Segoe UI" FontWeight="SemiBold"
                               Text="{Binding Movie.Rating.AverageRating, StringFormat={}{0:F1}, FallbackValue=N/A, TargetNullValue=N/A}"/>
                    <TextBlock Foreground="{StaticResource TextMuted}"
                               FontSize="13" FontFamily="Segoe UI"
                               Margin="6,0,0,0" VerticalAlignment="Center"
                               Text="{Binding Movie.Rating.NumVotes, StringFormat=({0:N0} votes), FallbackValue='', TargetNullValue=''}"/>
                </StackPanel>

                <!-- Add to Favourites button — disables and changes text once added -->
                <Button HorizontalAlignment="Left"
                        Margin="0,16,0,0"
                        Padding="20,10"
                        Command="{Binding AddToFavouritesCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GoldBtn}">
                            <Setter Property="Content" Value="★  Add to Favourites"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAlreadyFavourite}" Value="True">
                                    <Setter Property="Content" Value="✓  Added to Favourites"/>
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Genres -->
                <TextBlock Text="Genres"
                           Foreground="{StaticResource AccentGold}"
                           FontSize="16" FontWeight="SemiBold" FontFamily="Segoe UI"
                           Margin="0,24,0,8"/>
                <ItemsControl ItemsSource="{Binding Genres}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgCard}"
                                    CornerRadius="4" Padding="10,4" Margin="0,0,6,6">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource AccentGold}"
                                           FontSize="12" FontFamily="Segoe UI"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Description -->
                <TextBlock Text="Description"
                           Foreground="{StaticResource AccentGold}"
                           FontSize="16" FontWeight="SemiBold" FontFamily="Segoe UI"
                           Margin="0,24,0,8"/>
                <Border Background="{StaticResource BgCard}"
                        CornerRadius="6" Padding="16,12"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="1">
                    <TextBlock Text="{Binding Plot, FallbackValue='Loading description...'}"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="13" FontFamily="Segoe UI"
                               TextWrapping="Wrap"
                               LineHeight="20"
                               Opacity="0.85"/>
                </Border>

                <!-- Cast -->
                <TextBlock Text="Cast"
                           Foreground="{StaticResource AccentGold}"
                           FontSize="16" FontWeight="SemiBold" FontFamily="Segoe UI"
                           Margin="0,24,0,8"/>
                <ItemsControl ItemsSource="{Binding Cast}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgCard}"
                                    CornerRadius="6" Padding="12,10"
                                    Margin="0,0,0,6"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontWeight="SemiBold" FontFamily="Segoe UI"
                                               FontSize="13"/>
                                    <TextBlock Text="{Binding CharacterName}"
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="12" FontFamily="Segoe UI"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>