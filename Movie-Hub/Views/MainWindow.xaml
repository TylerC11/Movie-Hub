<Page x:Class="Movie_Hub.Views.MainWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="Movie Hub">

    <Page.Resources>
        <SolidColorBrush x:Key="BgDark"      Color="#0F0F0F"/>
        <SolidColorBrush x:Key="BgSidebar"   Color="#1A1A2E"/>
        <SolidColorBrush x:Key="AccentGold"  Color="#E2B96F"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#9E9E9E"/>
        <SolidColorBrush x:Key="NavHover"    Color="#2A2A4A"/>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"                Value="Transparent"/>
            <Setter Property="Foreground"                Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness"           Value="0"/>
            <Setter Property="FontSize"                  Value="14"/>
            <Setter Property="FontFamily"                Value="Segoe UI"/>
            <Setter Property="Padding"                   Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{StaticResource NavHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource BgDark}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{StaticResource BgSidebar}"
                BorderBrush="#2A2A4A"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <StackPanel DockPanel.Dock="Top" Margin="16,24,16,32">
                    <TextBlock Text="🎬" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Movie Hub"
                               Foreground="{StaticResource AccentGold}"
                               FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Top"
                           Text="BROWSE"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                           Margin="20,0,0,8"/>

                <StackPanel DockPanel.Dock="Top" Margin="8,0">
                    <Button Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateHomeCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Home" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButtonStyle}"
                            Command="{Binding NavigateFavouritesCommand}"
                            Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="❤️" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Favourites" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom"
                           Text="Movie Hub v1.0"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="10" FontFamily="Segoe UI"
                           HorizontalAlignment="Center" Margin="0,0,0,16"/>
            </DockPanel>
        </Border>


        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentPage}"
                        Focusable="False"/>
    </Grid>
</Page>
