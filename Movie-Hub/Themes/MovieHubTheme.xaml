<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- COLOURS -->
    <SolidColorBrush x:Key="BgDark"          Color="#0F0F0F"/>
    <SolidColorBrush x:Key="BgSidebar"       Color="#1A1A2E"/>
    <SolidColorBrush x:Key="BgCard"          Color="#1A1A2E"/>
    <SolidColorBrush x:Key="BgFilter"        Color="#16213E"/>
    <SolidColorBrush x:Key="BgInput"         Color="#1E1E3A"/>
    <SolidColorBrush x:Key="BgPoster"        Color="#0E0E28"/>
    <SolidColorBrush x:Key="AccentGold"      Color="#E2B96F"/>
    <SolidColorBrush x:Key="AccentGoldHover" Color="#F0C97E"/>
    <SolidColorBrush x:Key="AccentRed"       Color="#E05252"/>
    <SolidColorBrush x:Key="TextPrimary"     Color="#F5F5F5"/>
    <SolidColorBrush x:Key="TextMuted"       Color="#9E9E9E"/>
    <SolidColorBrush x:Key="BorderSubtle"    Color="#2A2A4A"/>
    <SolidColorBrush x:Key="NavHover"        Color="#2A2A4A"/>

    <!-- TYPOGRAPHY -->
    <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
    <sys:Double x:Key="FontSizeXS">10</sys:Double>
    <sys:Double x:Key="FontSizeSM">12</sys:Double>
    <sys:Double x:Key="FontSizeMD">13</sys:Double>
    <sys:Double x:Key="FontSizeLG">16</sys:Double>
    <sys:Double x:Key="FontSizeXL">22</sys:Double>
    <sys:Double x:Key="FontSizeHero">28</sys:Double>

    <!-- CONVERTERS -->
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- BUTTON — Gold / primary -->
    <Style x:Key="GoldBtn" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource AccentGold}"/>
        <Setter Property="Foreground"      Value="#0F0F0F"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSizeMD}"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontFamily"      Value="{StaticResource AppFont}"/>
        <Setter Property="Padding"         Value="16,8"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentGoldHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="#333"/>
                            <Setter Property="Foreground" Value="#666"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- BUTTON — Ghost / outline -->
    <Style x:Key="GhostBtn" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSizeMD}"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontFamily"      Value="{StaticResource AppFont}"/>
        <Setter Property="Padding"         Value="14,7"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource BgInput}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#444"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- BUTTON — Danger / red -->
    <Style x:Key="DangerBtn" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource AccentRed}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource AccentRed}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSizeSM}"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontFamily"      Value="{StaticResource AppFont}"/>
        <Setter Property="Padding"         Value="10,5"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#3A1A1A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- BUTTON — Sidebar nav -->
    <Style x:Key="NavButtonStyle" TargetType="Button">
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="Foreground"                 Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderThickness"            Value="0"/>
        <Setter Property="FontSize"                   Value="{StaticResource FontSizeMD}"/>
        <Setter Property="FontFamily"                 Value="{StaticResource AppFont}"/>
        <Setter Property="Padding"                    Value="16,12"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource NavHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- INPUT — TextBox -->
    <Style x:Key="InputStyle" TargetType="TextBox">
        <Setter Property="Background"               Value="{StaticResource BgInput}"/>
        <Setter Property="Foreground"               Value="{StaticResource TextPrimary}"/>
        <Setter Property="CaretBrush"               Value="{StaticResource AccentGold}"/>
        <Setter Property="BorderBrush"              Value="{StaticResource BorderSubtle}"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="Padding"                  Value="10,8"/>
        <Setter Property="FontSize"                 Value="{StaticResource FontSizeMD}"/>
        <Setter Property="FontFamily"               Value="{StaticResource AppFont}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- INPUT — ComboBox -->
    <Style x:Key="ComboStyle" TargetType="ComboBox">
        <Setter Property="Background"      Value="{StaticResource BgInput}"/>
        <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8,6"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSizeMD}"/>
        <Setter Property="FontFamily"      Value="{StaticResource AppFont}"/>
    </Style>

    <!-- CARD -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource BgCard}"/>
        <Setter Property="CornerRadius"    Value="8"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin"          Value="6"/>
        <Setter Property="Cursor"          Value="Hand"/>
    </Style>

</ResourceDictionary>